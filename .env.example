# OpenAI API Key
OPENAI_API_KEY=sk-xxx

# Postgres (use docker-compose for local dev)
DATABASE_URL=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Config
CHALLENGE_LOCK_TIMEOUT_MINUTES=5
DISPUTE_EXPIRY_HOURS=48

# Rate limits
RATE_LIMIT_AGENT_REGISTER=50    # Agent registrations per IP per 24h
RATE_LIMIT_DISPUTE_CREATE=5     # Disputes created per IP per hour
RATE_LIMIT_AGENT_ACTION=20      # Agent votes/comments per agent per hour
